{
  "name": "rcl-executor",
  "version": "1.0.0",
  "description": "Next generation Roblox scripting utility.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:free": "electron main-free.js",
    "build": "electron-builder",
    "build:pro": "electron-builder",
    "build:free": "electron-builder -c.main=main-free.js -c.productName=\"RCL Free\" -c.appId=\"com.rcl.executor.free\""
  },
  "build": {
    "appId": "com.rcl.executor",
    "productName": "RCL Executor",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "files": [
      "main.js",
      "main-free.js",
      "app.html",
      "app-free.html",
      "package.json",
      "icon.png",
      "index.html",
      "login.html",
      "firebase-config.js",
      "src/**/*"
    ],
    "asar": true
  },
  "author": "Panos",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  }
}
